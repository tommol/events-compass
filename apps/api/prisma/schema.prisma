generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  authoredEvents Event[]
  eventTokens    EventToken[]
}

model Event {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  status      EventStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User         @relation(fields: [authorId], references: [id])
  detail   EventDetail?
  tokens   EventToken[]
}

enum EventStatus {
  active
  deleted
  archived
}

model EventDetail {
  id String @id

  startAt DateTime?
  endsAt  DateTime?

  country    String?
  region     String?
  postalCode String?
  city       String?
  address    String?
  venue      String?

  websiteUrl   String?
  instagramUrl String?
  facebookUrl  String?
  ticketsUrl   String?

  event Event @relation(fields: [id], references: [id], onDelete: Cascade)
}

model EventToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime

  userId String
  user   User     @relation(fields: [userId], references: [id])

  eventId String
  event   Event    @relation(fields: [eventId], references: [id])

  @@index([userId])
  @@index([eventId])
}
